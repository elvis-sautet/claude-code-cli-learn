{
  "name": "camera-and-meetings",
  "version": "1.0.0",
  "private": true,
  "description": "Open the camera and launch free Jitsi video meetings. Type-safe frontend with E2E tests.",
  "type": "module",
  "scripts": {
    "build": "tsc",
